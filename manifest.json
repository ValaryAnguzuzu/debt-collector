{
  "manifest_version": 3,
  "name": "Debt Collector",
  "version": "0.1.0",
  "description": "Track distraction debt and repay it with focused work.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Debt Collector",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/blocker.js"],
      "css": ["content/blocker.css"],
      "run_at": "document_start"
    }
  ]
}
